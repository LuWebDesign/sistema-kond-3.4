# ============================================
# VARIABLES DE ENTORNO - SISTEMA KOND
# ============================================
# Copia este archivo a .env.local y completa con tus credenciales

# URL de tu proyecto Supabase
# Ejemplo: https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon key de Supabase (clave pública, segura para el cliente)
# La encuentras en: Dashboard > Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Activar Supabase (true) o usar localStorage (false)
# Durante la transición, usa false para probar sin romper nada
NEXT_PUBLIC_USE_SUPABASE=false

# Service Role Key (solo para scripts de migración en servidor)
# NUNCA expongas esta clave en el cliente
SUPABASE_SERVICE_ROLE_KEY=
